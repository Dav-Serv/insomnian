---
import Layout from './Layout.astro';

interface Props {
  title?: string;
  activeTab?: 'home' | 'soundscape' | 'diary' | 'tools' | 'setting';
}

const { title = "Tidur Nyenyak", activeTab } = Astro.props;

const pathname = Astro.url.pathname;
const currentActive = activeTab || (
  pathname === '/' || pathname === '/index.html' ? 'home' :
  pathname.startsWith('/soundscape') ? 'soundscape' :
  pathname.startsWith('/diary') ? 'diary' :
  pathname.startsWith('/tools') ? 'tools' :
  pathname.startsWith('/setting') ? 'setting' : 'home'
);

const menuItems = [
  { id: 'home', label: 'Home', path: '/' },
  { id: 'soundscape', label: 'Soundscape', path: '/soundscape' },
  { id: 'diary', label: 'Diary', path: '/diary' },
  { id: 'tools', label: 'Tools', path: '/tools' }
];
---

<Layout title={title}>
  <div class="flex flex-col md:flex-row min-h-screen bg-bg-dark text-white font-sans">
    <!-- Sidebar -->
    <aside class="w-full h-auto p-4 static z-10 flex flex-col md:w-[240px] md:h-screen md:sticky md:top-0 md:py-10 md:px-5 md:shadow-none bg-bg-sidebar shrink-0 box-border">

      <!-- Brand -->
      <div class="flex items-center gap-2.5 mb-4 justify-center md:mb-8 md:justify-start md:px-3">
        <svg class="text-accent shrink-0" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
        <span class="text-lg font-semibold text-accent whitespace-nowrap">Tidur Nyenyak</span>
      </div>

      <!-- Nav -->
      <nav class="flex flex-row justify-around gap-1 items-center md:flex-col md:gap-1 md:items-stretch md:grow">
        {menuItems.map((item) => (
          <a
            href={item.path}
            class:list={[
              'flex items-center gap-3 py-2.5 px-3 rounded-lg text-[13px] font-medium no-underline transition-all duration-200 w-full',
              currentActive === item.id
                ? 'bg-bg-active text-accent'
                : 'text-muted hover:text-white hover:bg-white/5'
            ]}
          >
            <div class="flex items-center justify-center w-5 h-5 shrink-0">
              {item.id === 'home' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                  <polyline points="9 22 9 12 15 12 15 22" />
                </svg>
              )}
              {item.id === 'soundscape' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill={currentActive === 'soundscape' ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
                </svg>
              )}
              {item.id === 'diary' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 6h9M4 12h7M4 18h9" />
                  <path d="M16 14.5L19.5 11a1.5 1.5 0 0 1 2 2l-3.5 3.5-3 1 1-3z" />
                </svg>
              )}
              {item.id === 'tools' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/>
                  <path d="m5 3 1 2.5L8.5 6 6 7 5 9.5 4 7 1.5 6 4 5 5 3Z"/>
                  <path d="m19 17 1 2.5 2.5.5-2.5 1-1 2.5-1-2.5-2.5-1 2.5-1 1-2.5Z"/>
                </svg>
              )}
            </div>
            <span>{item.label}</span>
          </a>
        ))}

        <!-- Divider pushed to bottom -->
        <div class="hidden md:block h-px bg-white/5 mt-auto mb-3 w-full"></div>

        <!-- User Profile (logged in) -->
        <a
          id="sidebar-user-profile"
          href="/setting"
          class:list={[
            'hidden items-center gap-3 py-2 px-3 rounded-lg no-underline transition-all duration-200 w-full group',
            currentActive === 'setting'
              ? 'bg-bg-active'
              : 'hover:bg-white/5'
          ]}
        >
          <div class:list={[
            'w-10 h-10 rounded-full bg-[#1a2729] border flex items-center justify-center shrink-0 overflow-hidden',
            currentActive === 'setting' ? 'border-accent/30' : 'border-white/8'
          ]}>
            <div id="sidebar-user-photo-container" class="w-full h-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent/60"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
          </div>
          <div class="flex flex-col">
            <span id="sidebar-username" class="text-[13px] font-semibold text-white group-hover:text-accent transition-colors">User</span>
            <span class="text-[11px] text-muted">Settings</span>
          </div>
        </a>

        <!-- Login Link (guest) -->
        <a
          id="sidebar-login-link"
          href="/auth"
          class="hidden items-center gap-3 py-2.5 px-3 rounded-lg no-underline transition-all duration-200 w-full group hover:bg-white/5"
        >
          <div class="w-10 h-10 rounded-full bg-[#1a2729] border border-white/8 flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
          </div>
          <div class="flex flex-col">
            <span class="text-[13px] font-semibold text-muted group-hover:text-accent transition-colors">Login</span>
            <span class="text-[11px] text-muted/60">Masuk ke akun Anda</span>
          </div>
        </a>
      </nav>
    </aside>

    <!-- Main Content -->
    <main class="grow p-6 md:p-14 overflow-y-auto box-border">
      <slot />
    </main>
  </div>
</Layout>

<script>
  import { isLoggedIn, getUser } from '../utils/auth.js';

  document.addEventListener('DOMContentLoaded', () => {
    const userProfile = document.getElementById('sidebar-user-profile');
    const loginLink = document.getElementById('sidebar-login-link');
    const usernameEl = document.getElementById('sidebar-username');
    const photoContainer = document.getElementById('sidebar-user-photo-container');

    if (isLoggedIn()) {
      const user = getUser();
      if (userProfile) {
        userProfile.classList.remove('hidden');
        userProfile.classList.add('flex');
      }
      if (loginLink) loginLink.classList.add('hidden');
      if (usernameEl && user) {
        usernameEl.textContent = user.username || 'User';
      }
      if (photoContainer && user && user.photo) {
        const photoUrl = `http://127.0.0.1:8000/storage/${user.photo}`;
        photoContainer.innerHTML = `<img src="${photoUrl}" alt="Photo" class="w-full h-full object-cover" onerror="this.src='data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2218%22 height=%2218%22 viewBox=%220%22><circle cx=%229%22 cy=%229%22 r=%228%22 fill=%22%23ccc%22 /></svg>'"/>`;
      }
    } else {
      if (loginLink) {
        loginLink.classList.remove('hidden');
        loginLink.classList.add('flex');
      }
      if (userProfile) userProfile.classList.add('hidden');
    }
  });
</script>
