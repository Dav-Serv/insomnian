---
interface Props {
	title?: string;
}

const { title = "Tidur Nyenyak" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-bg-dark text-white min-h-screen">
		<slot />
	</body>
</html>

<style is:global>
	@import "tailwindcss";

	@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap');

	@theme {
		--font-sans: 'Plus Jakarta Sans', system-ui, -apple-system, sans-serif;
		--color-bg-dark: #080c0d;
		--color-bg-sidebar: #090f10;
		--color-bg-active: #132225;
		--color-accent: #4ed0c8;
		--color-accent-hover: #5ce3db;
		--color-muted: #8e9fa2;

		--animate-breath: breath 8s infinite ease-in-out;

		@keyframes breath {
			0%, 100% {
				transform: scale(1);
				background-color: rgba(78, 208, 200, 0.15);
			}
			50% {
				transform: scale(1.4);
				background-color: rgba(78, 208, 200, 0.3);
				box-shadow: 0 0 20px rgba(78, 208, 200, 0.25);
			}
		}
	}

	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		font-family: var(--font-sans);
	}
</style>
