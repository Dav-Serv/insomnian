      audioTimeCurrent.textContent = '00:00';
      audioTimeDuration.textContent = '00:00';
    }

    btnAudioPlay.addEventListener('click', () => {
      if (isAudioPlaying) {
        pauseAudio();
      } else {
        playAudio();
      }
    });

    audioEl.addEventListener('timeupdate', () => {
      if (audioEl.duration) {
        const pct = (audioEl.currentTime / audioEl.duration) * 100;
        audioProgressBar.value = pct;
        audioTimeCurrent.textContent = formatTime(audioEl.currentTime);
      }
    });

    audioEl.addEventListener('loadedmetadata', () => {
      audioTimeDuration.textContent = formatTime(audioEl.duration);
    });

    audioProgressBar.addEventListener('input', (e) => {
      if (audioEl.duration) {
