      const computedStyle = window.getComputedStyle(breathCircle);
      const matrix = computedStyle.transform;
      breathCircle.style.transition = 'none';
      breathOuterRing.style.transition = 'none';
      breathCircle.style.transform = matrix;
      breathOuterRing.style.transform = matrix;
    }

    function stopBreathingTimer() {
