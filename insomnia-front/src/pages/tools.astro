          document.getElementById('breath-modal-subtitle').textContent = `Cycle target: ${breathCycleMax} • ${breathIntervals.inhale_seconds}-${breathIntervals.hold_seconds}-${breathIntervals.exhale_seconds}`;
        }
      } catch (err) {
        console.warn("Using offline fallback breathing setup:", err);
        // Fallback standard 4-7-8
