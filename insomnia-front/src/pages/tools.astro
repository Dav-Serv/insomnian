      categoryTabsHeader.innerHTML = '';
      if (categoriesList.length === 0) {
        // Offline default categories fallback
        categoriesList = [
          { name: 'Pernapasan', slug: 'pernapasan' },
          { name: 'Edukasi & Sleep Hygiene', slug: 'edukasi' }
        ];
      }

      categoriesList.forEach((cat, index) => {
        const btn = document.createElement('button');
        btn.setAttribute('data-slug', cat.slug);
        btn.className = `cat-tab py-2 px-4 rounded-full cursor-pointer transition-all text-xs font-semibold ${index === 0 ? 'bg-accent/10 border border-accent/20 text-accent' : 'bg-transparent border border-white/5 text-muted hover:text-white'}`;
        btn.textContent = cat.name;
        btn.addEventListener('click', () => loadCategoryItems(cat.slug));
        categoryTabsHeader.appendChild(btn);
      });

      if (categoriesList.length > 0) {
        loadCategoryItems(categoriesList[0].slug);
      }
    });


    // ==========================================
    // 🚀 CARD CLICK HANDLERS (HOMEPAGE STATICS)
    // ==========================================
    document.getElementById('card-breathing').addEventListener('click', () => {
      launchBreathingExercise(1);
    });

    document.getElementById('card-meditation').addEventListener('click', () => {
      // Launch progressive muscle relaxation (which is ID 2 from Tools recommendation)
      launchMeditationPlayer(2);
    });

    document.getElementById('card-braindump').addEventListener('click', () => {
      launchBrainDump();
    });
  });
</script>

