---
import Sidebar from '../layouts/Sidebar.astro';

// Tools page
---

<script is:inline>
  // Segera alihkan jika pengguna belum masuk (mencegah kedipan konten/glitch)
  if (!localStorage.getItem('tidurnyenyak_token')) {
    window.location.href = '/auth';
  }
</script>

<Sidebar title="Tidur Nyenyak - Tools" activeTab="tools">
  <div class="max-w-[1000px] mx-auto py-2">
    <!-- Header -->
    <header class="mb-8">
      <h1 class="text-4xl font-semibold tracking-tight text-white mb-2">Wind-Down Tools</h1>
      <p class="text-sm md:text-base text-muted max-w-[650px] leading-relaxed">
        Prepare your mind and environment for a restful night. These tools are designed to gently lower your cognitive load.
      </p>
    </header>

    <!-- Main Sleep Window Card -->
    <div class="bg-[#0b1112] border border-white/5 rounded-3xl p-5 sm:p-6 md:p-8 flex flex-col min-[520px]:flex-row justify-between items-center min-[520px]:items-stretch gap-6 sm:gap-8 mb-10 shadow-[0_12px_40px_rgba(0,0,0,0.4)] relative overflow-hidden">
      <!-- Ambient Glow behind card -->
      <div class="absolute -right-24 -top-24 w-80 h-80 rounded-full bg-accent/5 blur-[80px] pointer-events-none"></div>
      
      <!-- Left side: Text details and Bedtime target info -->
      <div class="flex-1 w-full flex flex-col justify-between min-h-0 min-[520px]:min-h-[200px] sm:min-h-[220px]">
        <div>
          <!-- Title with Clock Icon -->
          <div class="flex items-center gap-2 text-accent mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
            <span class="font-semibold text-sm sm:text-base tracking-wide">Sleep Window</span>
          </div>
          
          <!-- Subtitle -->
          <p class="text-xs sm:text-sm text-muted/80 max-w-[420px] leading-relaxed mb-5">
            Your optimal time to fall asleep based on your wake-up goal. Start winding down now to hit this window.
          </p>
        </div>
        
        <!-- Sleep Details Block -->
        <div class="mt-auto w-full">
          <!-- Target Bedtime Row -->
          <div class="flex justify-between items-end pb-3 border-b border-white/5">
            <div class="flex flex-col gap-0.5">
              <span class="text-[10px] sm:text-xs text-muted/65 tracking-wider uppercase font-semibold">Target</span>
              <span class="text-xs sm:text-sm text-muted/90 font-medium">Bedtime</span>
            </div>
            <div class="text-right flex items-baseline gap-0.5 sm:gap-1">
              <span id="target-bedtime-val" class="text-3xl sm:text-4xl font-light text-white tracking-tight">10:30</span>
              <span id="target-bedtime-ampm" class="text-lg sm:text-xl font-light text-white/70">PM</span>
            </div>
          </div>
          
          <!-- Time Remaining Row -->
          <div class="flex justify-between items-center pt-3">
            <span class="text-xs sm:text-sm text-muted/80 font-medium">Time remaining</span>
            <span id="time-remaining-val" class="text-xl sm:text-2xl font-semibold text-accent tracking-tight">--</span>
          </div>
        </div>
      </div>
      
      <!-- Right side: Circular progress visualization -->
      <div class="flex items-center justify-center shrink-0 w-full min-[520px]:w-auto mt-2 min-[520px]:mt-0 min-[520px]:px-2">
        <div class="relative w-[130px] h-[130px] min-[360px]:w-[150px] min-[360px]:h-[150px] sm:w-[170px] sm:h-[170px] md:w-[210px] md:h-[210px] rounded-full flex items-center justify-center">
          <!-- Outermost Glowing Ring background -->
          <div class="absolute inset-0 rounded-full border-[6px] sm:border-[8px] border-accent/10"></div>
          
          <!-- Active colored segment ring with gradient look -->
          <div id="sleep-window-ring" class="absolute inset-0 rounded-full border-[6px] sm:border-[8px] border-transparent border-t-accent border-r-accent border-l-accent rotate-[45deg] filter drop-shadow-[0_0_8px_rgba(78,208,200,0.35)] transition-all duration-1000"></div>
          
          <!-- Inner Dark Circle -->
          <div class="w-[98px] h-[98px] min-[360px]:w-[114px] min-[360px]:h-[114px] sm:w-[130px] sm:h-[130px] md:w-[160px] md:h-[160px] rounded-full bg-[#080d0e] border border-white/5 flex flex-col items-center justify-center shadow-inner relative group/moon">
            <div class="absolute inset-0 rounded-full bg-accent/2 opacity-0 group-hover/moon:opacity-100 transition-opacity duration-500"></div>
            
            <!-- Crescent Moon Icon -->
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 min-[360px]:w-6 min-[360px]:h-6 md:w-8 md:h-8 text-accent mb-1 md:mb-2 filter drop-shadow-[0_0_8px_rgba(78,208,200,0.3)] transition-transform duration-500 group-hover/moon:scale-110" viewBox="0 0 24 24" fill="currentColor">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
            </svg>
            <span id="sleep-window-status-label" class="text-[8px] min-[360px]:text-[9px] sm:text-[10px] md:text-[11px] text-muted/80 font-medium tracking-wider uppercase">Winding Down</span>
          </div>
        </div>
      </div>
    </div>

    <style is:global>
      /* Cleaned up guided-exercises-grid style to use tailwind responsive classes instead */
    </style>

    <!-- Guided Exercises Section -->
    <div>
      <div class="flex justify-between items-center mb-6">
        <h2 class="text-2xl font-semibold text-white tracking-tight">Guided Exercises</h2>
        <button id="btn-view-all" class="bg-transparent border-none text-sm font-semibold text-accent hover:text-accent-hover cursor-pointer transition-colors flex items-center gap-1">
          View all
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </button>
      </div>
      
      <!-- Cards Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
        <!-- 4-7-8 Breathing Card -->
        <div id="card-breathing" class="bg-[#0b1112] border border-white/5 rounded-2xl p-6 flex flex-col justify-between min-h-[190px] transition-all duration-300 hover:border-accent/25 hover:translate-y-[-4px] hover:shadow-[0_10px_30px_rgba(0,0,0,0.3)] group cursor-pointer">
          <div>
            <!-- Icon Container -->
            <div class="w-10 h-10 rounded-xl bg-accent/5 border border-accent/10 flex items-center justify-center text-accent mb-5 group-hover:bg-accent/10 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 8h14M3 12h18M6 16h12"/>
              </svg>
            </div>
            
            <h3 class="text-base font-semibold text-white mb-1.5 group-hover:text-accent transition-colors">4-7-8 Breathing</h3>
            <p class="text-xs text-muted/75 leading-relaxed">Calm your nervous system</p>
          </div>
          
          <div class="flex items-center gap-1.5 text-[11px] text-muted/50 mt-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
            <span>5 min</span>
          </div>
        </div>

        <!-- Meditasi Card -->
        <div id="card-meditation" class="bg-[#0b1112] border border-white/5 rounded-2xl p-6 flex flex-col justify-between min-h-[190px] transition-all duration-300 hover:border-[#4eb0d0]/25 hover:translate-y-[-4px] hover:shadow-[0_10px_30px_rgba(0,0,0,0.3)] group cursor-pointer">
          <div>
            <!-- Icon Container -->
            <div class="w-10 h-10 rounded-xl bg-[#4eb0d0]/5 border border-[#4eb0d0]/10 flex items-center justify-center text-[#4eb0d0] mb-5 group-hover:bg-[#4eb0d0]/10 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="5" r="1"/>
                <path d="m9 20 3-6 3 6M6 8h12M12 8v6"/>
              </svg>
            </div>
            
            <h3 id="meditation-title-card" class="text-base font-semibold text-white mb-1.5 group-hover:text-[#4eb0d0] transition-colors">Meditasi & Relaksasi</h3>
            <p id="meditation-desc-card" class="text-xs text-muted/75 leading-relaxed">Tenangkan pikiran Anda</p>
          </div>
          
          <div class="flex items-center gap-1.5 text-[11px] text-muted/50 mt-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
            <span id="meditation-duration-card">10 min</span>
          </div>
        </div>

        <!-- Brain Dump Card -->
        <div id="card-braindump" class="bg-[#0b1112] border border-white/5 rounded-2xl p-6 flex flex-col justify-between min-h-[190px] transition-all duration-300 hover:border-orange-400/25 hover:translate-y-[-4px] hover:shadow-[0_10px_30px_rgba(0,0,0,0.3)] group cursor-pointer">
          <div>
            <!-- Icon Container -->
            <div class="w-10 h-10 rounded-xl bg-orange-400/5 border border-orange-400/10 flex items-center justify-center text-orange-400/80 mb-5 group-hover:bg-orange-400/10 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
              </svg>
            </div>
            
            <h3 class="text-base font-semibold text-white mb-1.5 group-hover:text-orange-400/80 transition-colors">Brain Dump</h3>
            <p class="text-xs text-muted/75 leading-relaxed">Clear tomorrow's worries</p>
          </div>
          
          <div class="flex items-center gap-1.5 text-[11px] text-muted/50 mt-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
            <span>Unguided</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ============================================================== -->
  <!-- MODAL INTERAKTIF OVERLAY -->
  <!-- ============================================================== -->

  <!-- 1. Breathing Modal -->
  <div id="breathing-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/90 backdrop-blur-md opacity-0 pointer-events-none transition-all duration-300">
    <div class="bg-[#0b1213] border border-white/10 rounded-3xl p-8 max-w-md w-full mx-4 flex flex-col items-center relative text-center">
      <button class="modal-close absolute top-4 right-4 text-muted hover:text-white bg-transparent border-none text-xl cursor-pointer">&times;</button>
      <h3 id="breath-modal-title" class="text-xl font-semibold text-white mb-2">4-7-8 Breathing</h3>
      <p id="breath-modal-subtitle" class="text-xs text-muted mb-8">Relax your mind & calm your nervous system</p>
      
      <!-- Animated Breathing Ring & Circle -->
      <div class="relative w-64 h-64 flex items-center justify-center mb-8">
        <div id="breath-outer-ring" class="absolute w-48 h-48 rounded-full bg-accent/5 border border-accent/20 transition-all duration-1000 ease-in-out"></div>
        <div id="breath-circle" class="absolute w-36 h-36 rounded-full bg-accent/15 border border-accent/30 shadow-[0_0_40px_rgba(78,208,200,0.15)] flex flex-col items-center justify-center transition-all duration-1000 ease-in-out">
          <span id="breath-instruction" class="text-white text-lg font-bold tracking-wide">Ready</span>
          <span id="breath-timer" class="text-accent text-3xl font-light mt-1">4</span>
        </div>
      </div>

      <!-- Stats / Cycles info -->
      <div class="flex gap-8 mb-8">
        <div class="text-center">
          <span class="block text-[10px] text-muted tracking-wider uppercase font-semibold">Cycles</span>
          <span id="breath-cycles" class="text-lg font-bold text-white">0 / 4</span>
        </div>
        <div class="text-center">
          <span class="block text-[10px] text-muted tracking-wider uppercase font-semibold">Phase</span>
          <span id="breath-phase" class="text-lg font-bold text-accent">--</span>
        </div>
      </div>

      <!-- Controls -->
      <div class="flex gap-4 w-full">
        <button id="btn-breath-start" class="flex-1 bg-accent text-[#080c0d] border-none rounded-xl py-3 px-6 font-semibold text-sm cursor-pointer transition-all hover:bg-accent-hover">Start</button>
        <button id="btn-breath-reset" class="bg-white/5 border border-white/10 text-white rounded-xl py-3 px-6 font-semibold text-sm cursor-pointer transition-all hover:bg-white/10">Reset</button>
      </div>
    </div>
  </div>

  <!-- 2. Meditation / Audio Player Modal -->
  <div id="audio-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/90 backdrop-blur-md opacity-0 pointer-events-none transition-all duration-300">
    <div class="bg-[#0b1213] border border-white/10 rounded-3xl p-6 md:p-8 max-w-2xl w-full mx-4 flex flex-col md:flex-row gap-6 relative">
      <button class="modal-close absolute top-4 right-4 text-muted hover:text-white bg-transparent border-none text-xl cursor-pointer z-10">&times;</button>
      
      <!-- Player Panel Left -->
      <div class="flex-1 flex flex-col items-center text-center justify-center">
        <!-- CD / Art Visualizer -->
        <div class="relative w-44 h-44 rounded-full bg-[#121f21] border border-white/5 flex items-center justify-center shadow-2xl mb-5 overflow-hidden group">
          <div id="audio-visualizer-glow" class="absolute inset-0 bg-accent/5 rounded-full scale-90 group-hover:scale-105 transition-transform duration-1000 blur-xl"></div>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-accent animate-pulse" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9v-4h2v4zm0-6H9V8h2v2zm4 6h-2v-4h2v4zm0-6h-2V8h2v2z"/>
          </svg>
        </div>

        <h3 id="audio-track-title" class="text-lg font-semibold text-white mb-0.5">Relaksasi Otot Progresif</h3>
        <p id="audio-track-subtitle" class="text-xs text-muted mb-6">Dr. Sleep Specialist</p>

        <!-- Hidden Native Audio -->
        <audio id="modal-audio-element" class="hidden"></audio>

        <!-- Progress Slider -->
        <div class="w-full mb-4">
          <input type="range" id="audio-progress-bar" value="0" class="w-full h-1 bg-white/10 rounded-lg appearance-none cursor-pointer accent-accent focus:outline-none" />
          <div class="flex justify-between text-[10px] text-muted mt-2">
            <span id="audio-time-current">00:00</span>
            <span id="audio-time-duration">30:00</span>
          </div>
        </div>

        <!-- Audio Controls -->
        <div class="flex items-center gap-6">
          <button id="btn-audio-prev-15" class="bg-transparent border-none text-muted hover:text-white cursor-pointer" title="-15s">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12.066 11.2a1 1 0 000 1.6l5.334 4A1 1 0 0019 16V8a1 1 0 00-1.6-.8l-5.334 4zM4.066 11.2a1 1 0 000 1.6l5.334 4A1 1 0 0011 16V8a1 1 0 00-1.6-.8l-5.334 4z"/>
            </svg>
          </button>
          <button id="btn-audio-play" class="w-12 h-12 rounded-full bg-accent text-[#080c0d] flex items-center justify-center border-none cursor-pointer transition-transform hover:scale-105 hover:bg-accent-hover shadow-lg">
            <svg id="audio-play-icon" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z"/>
            </svg>
            <svg id="audio-pause-icon" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 hidden" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
            </svg>
          </button>
          <button id="btn-audio-next-15" class="bg-transparent border-none text-muted hover:text-white cursor-pointer" title="+15s">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 5v14l8.561-6.226a1 1 0 000-1.548L13 5zM3 5v14l8.561-6.226a1 1 0 000-1.548L3 5z"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Playlist / Chapters Panel Right -->
      <div class="flex-1 border-t md:border-t-0 md:border-l border-white/5 pt-5 md:pt-0 md:pl-6 flex flex-col justify-start">
        <h4 class="text-sm font-semibold text-white mb-3">Panduan Sesi (Chapters)</h4>
        <div id="audio-chapters-list" class="flex flex-col gap-2 overflow-y-auto max-h-[220px] md:max-h-[300px] pr-2">
          <!-- Chapters will be loaded dynamically -->
        </div>
      </div>
    </div>
  </div>

  <!-- 3. Article Modal -->
  <div id="article-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/90 backdrop-blur-md opacity-0 pointer-events-none transition-all duration-300">
    <div class="bg-[#0b1213] border border-white/10 rounded-3xl p-6 md:p-8 max-w-xl w-full mx-4 flex flex-col relative max-h-[85vh]">
      <button class="modal-close absolute top-4 right-4 text-muted hover:text-white bg-transparent border-none text-xl cursor-pointer z-10">&times;</button>
      
      <div class="overflow-y-auto pr-2">
        <header class="mb-6 border-b border-white/5 pb-4">
          <span id="article-readtime" class="text-[10px] text-accent tracking-wider uppercase font-semibold">3 min read</span>
          <h3 id="article-title" class="text-xl md:text-2xl font-bold text-white mt-1">Panduan Kamar Ideal</h3>
        </header>
        <article id="article-body" class="text-sm text-muted/90 leading-relaxed font-sans prose prose-invert max-w-none">
          <!-- Article HTML loaded dynamically -->
        </article>
      </div>
    </div>
  </div>

  <!-- 4. Brain Dump Modal -->
  <div id="braindump-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/90 backdrop-blur-md opacity-0 pointer-events-none transition-all duration-300">
    <div class="bg-[#0b1213] border border-white/10 rounded-3xl p-8 max-w-lg w-full mx-4 flex flex-col relative text-center relative overflow-hidden">
      <button class="modal-close absolute top-4 right-4 text-muted hover:text-white bg-transparent border-none text-xl cursor-pointer z-10">&times;</button>
      
      <!-- Stars BG for animation -->
      <div id="braindump-stars" class="absolute inset-0 pointer-events-none opacity-40"></div>

      <div id="braindump-input-stage" class="transition-all duration-500">
        <h3 class="text-xl font-semibold text-white mb-2">Brain Dump</h3>
        <p class="text-xs text-muted mb-6">Write down everything keeping you awake, then release it into the dark.</p>
        
        <textarea id="braindump-textarea" class="w-full bg-[#121f21]/30 border border-white/10 rounded-2xl p-4 text-white text-sm outline-none transition-all focus:border-accent/40 font-sans resize-none h-40 mb-6" placeholder="Ketik apa saja yang mengganggu pikiran Anda... (Tugas besok, kekhawatiran, ide)"></textarea>
        
        <button id="btn-braindump-release" class="w-full bg-accent text-[#080c0d] border-none rounded-xl py-3.5 px-6 font-semibold text-sm cursor-pointer transition-all hover:bg-accent-hover">Release Into the Night</button>
      </div>

      <div id="braindump-success-stage" class="hidden opacity-0 transition-all duration-1000 flex flex-col items-center py-8">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-accent mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
        </svg>
        <h3 class="text-xl font-semibold text-white mb-2">Let It Go</h3>
        <p class="text-xs text-muted max-w-[280px]">Your thoughts have been cleared. Take a deep breath. You are ready to rest.</p>
        <button id="btn-braindump-done" class="mt-8 bg-white/5 border border-white/10 text-white rounded-xl py-2.5 px-6 font-semibold text-sm cursor-pointer transition-all hover:bg-white/10">Back to Tools</button>
      </div>
    </div>
  </div>

  <!-- 5. Category Explorer Modal -->
  <div id="category-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/90 backdrop-blur-md opacity-0 pointer-events-none transition-all duration-300">
    <div class="bg-[#0b1213] border border-white/10 rounded-3xl p-6 md:p-8 max-w-2xl w-full mx-4 flex flex-col relative max-h-[85vh]">
      <button class="modal-close absolute top-4 right-4 text-muted hover:text-white bg-transparent border-none text-xl cursor-pointer z-10">&times;</button>
      
      <h3 class="text-xl font-bold text-white mb-6">Explore Wind-Down Tools</h3>
      
      <!-- Categories switch tabs -->
      <div class="flex border-b border-white/5 gap-4 mb-6" id="category-tabs-header">
        <!-- Load category buttons dynamically -->
      </div>

      <!-- Items Grid -->
      <div class="overflow-y-auto pr-2 flex-1">
        <div id="category-items-grid" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <!-- Load items dynamically -->
        </div>
      </div>
    </div>
  </div>

</Sidebar>

<!-- ============================================================== -->
  <!-- PAGE LOGIC (CLIENT SIDE) -->
  <!-- ============================================================== -->
<script>
  import { getToken, isLoggedIn } from '../utils/auth.js';
  import { apiGetTools, apiGetToolsByCategory, apiGetToolDetail, apiGetDiary } from '../utils/api.js';

  document.addEventListener('astro:page-load', async () => {
    if (!isLoggedIn()) return;
    const token = getToken();

    // ==========================================
    // ⏰ SLEEP WINDOW COUNTDOWN DYNAMICS
    // ==========================================
    const bedtimeValEl = document.getElementById('target-bedtime-val');
    const bedtimeAmpmEl = document.getElementById('target-bedtime-ampm');
    const timeRemainingEl = document.getElementById('time-remaining-val');
    const statusLabelEl = document.getElementById('sleep-window-status-label');
    const sleepWindowRing = document.getElementById('sleep-window-ring');

    let targetHour = 22; // 10:30 PM default (22:30)
    let targetMinute = 30;

    // Optional: Fetch latest wake time from diary and subtract 8 hours
    try {
      const diaryRes = await apiGetDiary(token);
      if (diaryRes.ok && diaryRes.data.success && diaryRes.data.data.length > 0) {
        const latestLog = diaryRes.data.data[0]; // Terakhir
        if (latestLog && latestLog.wake_time) {
          const wakeDate = new Date(latestLog.wake_time);
          if (!isNaN(wakeDate.getTime())) {
            // Subtract 8 hours to get target bedtime
            wakeDate.setHours(wakeDate.getHours() - 8);
            targetHour = wakeDate.getHours();
            targetMinute = wakeDate.getMinutes();

            // format Bedtime UI
            let displayH = targetHour;
            let ampm = 'PM';
            if (displayH >= 12) {
              ampm = 'PM';
              if (displayH > 12) displayH -= 12;
            } else {
              ampm = 'AM';
              if (displayH === 0) displayH = 12;
            }
            const displayM = targetMinute < 10 ? `0${targetMinute}` : targetMinute;
            
            if (bedtimeValEl) bedtimeValEl.textContent = `${displayH}:${displayM}`;
            if (bedtimeAmpmEl) bedtimeAmpmEl.textContent = ampm;
          }
        }
      }
    } catch (err) {
      console.warn("Unable to fetch custom sleep window target from diary history:", err);
    }

    // Live Clock Countdown
    function updateCountdown() {
      const now = new Date();
      const targetTime = new Date();
      targetTime.setHours(targetHour, targetMinute, 0, 0);

      // If bedtime already passed for today, set to tomorrow's bedtime
      if (now > targetTime) {
        targetTime.setDate(targetTime.getDate() + 1);
      }

      const diffMs = targetTime.getTime() - now.getTime();
      const diffMins = Math.floor(diffMs / 60000);
      const hours = Math.floor(diffMins / 60);
      const mins = diffMins % 60;

      // Update remaining text
      if (timeRemainingEl) {
        if (hours > 12) {
          // If bedtime is far away, say "Sleep finished / day mode"
          timeRemainingEl.textContent = `${hours}h ${mins}m`;
          if (statusLabelEl) statusLabelEl.textContent = "Prepare Day";
          if (sleepWindowRing) sleepWindowRing.style.transform = `rotate(0deg)`;
        } else {
          timeRemainingEl.textContent = `${hours}h ${mins}m`;
          if (statusLabelEl) statusLabelEl.textContent = "Winding Down";
          // dynamic rotate based on 8h wind-down window
          const pct = Math.min(100, Math.max(0, (diffMins / 480) * 100)); // pct of 8 hours
          const rotateDeg = 45 + (100 - pct) * 3.6;
          if (sleepWindowRing) sleepWindowRing.style.transform = `rotate(${rotateDeg}deg)`;
        }
      }
    }

    updateCountdown();
    const clockInterval = setInterval(updateCountdown, 60000);

    // Clean up interval on page leave (astro:before-preparation)
    document.addEventListener('astro:before-preparation', () => {
      clearInterval(clockInterval);
    }, { once: true });


