    function resetBreathingUI() {
      breathCycleCurrent = 0;
      updateBreathingStats(0, '--');
      breathInstructionText.textContent = "Ready";
      breathTimerText.textContent = breathIntervals.inhale_seconds;
      btnBreathStart.textContent = "Start";
      btnBreathStart.className = "flex-1 bg-accent text-[#080c0d] border-none rounded-xl py-3 px-6 font-semibold text-sm cursor-pointer transition-all hover:bg-accent-hover";
      
      // Reset circle scaling
      breathCircle.style.transform = 'scale(1)';
      breathOuterRing.style.transform = 'scale(1)';
      breathOuterRing.classList.remove('border-accent', 'border-orange-400');
    }

    function updateBreathingStats(cycle, phase) {
      breathCyclesText.textContent = `${cycle} / ${breathCycleMax}`;
      breathPhaseText.textContent = phase;
    }

    function startBreathingTimer() {
      if (breathRunning) {
        pauseBreathingTimer();
        return;
      }

      breathRunning = true;
      btnBreathStart.textContent = "Pause";
      btnBreathStart.className = "flex-1 bg-white/10 border border-white/10 text-white rounded-xl py-3 px-6 font-semibold text-sm cursor-pointer transition-all hover:bg-white/20";
      
      let phase = 'inhale'; // inhale, hold, exhale
      let countdown = breathIntervals.inhale_seconds;
      breathCycleCurrent = 1;
      
      updateBreathingStats(breathCycleCurrent, 'Inhale');
      breathInstructionText.textContent = 'Inhale';
      breathTimerText.textContent = countdown;

      // Circle expands on inhale
      breathCircle.style.transform = 'scale(1.5)';
      breathOuterRing.style.transform = 'scale(1.7)';
      breathOuterRing.style.transition = `all ${breathIntervals.inhale_seconds}s ease-in-out`;
      breathCircle.style.transition = `all ${breathIntervals.inhale_seconds}s ease-in-out`;

      breathInterval = setInterval(() => {
        countdown--;
        
        if (countdown <= 0) {
          if (phase === 'inhale') {
            // transition to hold
            phase = 'hold';
            countdown = breathIntervals.hold_seconds;
            updateBreathingStats(breathCycleCurrent, 'Hold');
            breathInstructionText.textContent = 'Hold';
            
            // Hold style: circle stays big, pulses slightly, or ring changes color
            breathOuterRing.style.transition = 'all 1s ease-in-out';
            breathOuterRing.classList.add('border-orange-400/50');
          } else if (phase === 'hold') {
            // transition to exhale
            phase = 'exhale';
            countdown = breathIntervals.exhale_seconds;
            updateBreathingStats(breathCycleCurrent, 'Exhale');
            breathInstructionText.textContent = 'Exhale';
            
            // Circle shrinks on exhale
            breathCircle.style.transform = 'scale(1)';
            breathOuterRing.style.transform = 'scale(1)';
            breathOuterRing.classList.remove('border-orange-400/50');
            breathOuterRing.style.transition = `all ${breathIntervals.exhale_seconds}s ease-in-out`;
            breathCircle.style.transition = `all ${breathIntervals.exhale_seconds}s ease-in-out`;
          } else if (phase === 'exhale') {
            // Complete cycle
            if (breathCycleCurrent >= breathCycleMax) {
              // Finished
              stopBreathingTimer();
              breathInstructionText.textContent = 'Finished';
              breathTimerText.textContent = '☺';
              updateBreathingStats(breathCycleMax, 'Done');
              return;
            } else {
              breathCycleCurrent++;
              phase = 'inhale';
              countdown = breathIntervals.inhale_seconds;
              updateBreathingStats(breathCycleCurrent, 'Inhale');
              breathInstructionText.textContent = 'Inhale';
              
              // Circle expands
              breathCircle.style.transform = 'scale(1.5)';
              breathOuterRing.style.transform = 'scale(1.7)';
              breathOuterRing.style.transition = `all ${breathIntervals.inhale_seconds}s ease-in-out`;
              breathCircle.style.transition = `all ${breathIntervals.inhale_seconds}s ease-in-out`;
            }
          }
        }

        breathTimerText.textContent = countdown;
      }, 1000);
    }

    function pauseBreathingTimer() {
      breathRunning = false;
      clearInterval(breathInterval);
      btnBreathStart.textContent = "Resume";
      btnBreathStart.className = "flex-1 bg-accent text-[#080c0d] border-none rounded-xl py-3 px-6 font-semibold text-sm cursor-pointer transition-all hover:bg-accent-hover";
      
