---
import Sidebar from '../layouts/Sidebar.astro';

// Settings Page
---

<script is:inline>
  // Segera alihkan jika pengguna belum masuk (mencegah kedipan konten/glitch)
  if (!localStorage.getItem('tidurnyenyak_token')) {
    window.location.href = '/auth';
  }
</script>

<Sidebar title="Tidur Nyenyak - Settings" activeTab="setting">
  <div class="max-w-[1100px] mx-auto">
    <header class="mb-10">
      <h1 class="text-3xl font-bold m-0 mb-2 text-white">Pengaturan (Settings)</h1>
      <p class="text-base text-muted m-0">Atur profil, preferensi aplikasi, dan pengingat jadwal tidur Anda.</p>
    </header>

    <div class="flex flex-col gap-8 items-start max-w-3xl mx-auto">
      <!-- Settings Form -->
      <main class="flex flex-col gap-6 w-full">
        <form id="profile-form" class="flex flex-col gap-6">
          <div class="bg-[#0d1618] border border-white/2 rounded-3xl p-8">
            <h2 class="text-xl font-semibold m-0 mb-6 text-white">Informasi Profil</h2>
            
            <div class="flex items-center gap-6 mb-6">
              <div id="profile-photo-container" class="w-20 h-20 rounded-full bg-[#121e20] border-2 border-accent/25 flex items-center justify-center text-accent overflow-hidden shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                  <circle cx="12" cy="7" r="4" />
                </svg>
              </div>
              <div class="flex gap-3">
                <input type="file" id="profile-photo-input" accept="image/*" class="hidden" />
                <button type="button" id="change-photo-btn" class="bg-accent/8 border border-accent/20 text-accent py-2.5 px-4.5 rounded-lg text-sm font-semibold cursor-pointer transition-all duration-200 hover:bg-accent/15">Ubah Foto</button>
                <button type="button" id="remove-photo-btn" class="bg-none border border-white/6 text-[#8e9fa2] py-2.5 px-4.5 rounded-lg text-sm font-medium cursor-pointer transition-all duration-200 hover:border-red-500/30 hover:text-red-400">Hapus</button>
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-5">
              <div class="flex flex-col gap-2">
                <label for="display-name" class="text-sm text-[#8e9fa2] font-medium">Nama Tampilan</label>
                <input type="text" id="display-name" required class="bg-white/2 border border-white/5 rounded-xl py-3.5 px-4 text-white font-inherit text-sm transition-all focus:outline-none focus:border-accent/40" />
              </div>
              
              <div class="flex flex-col gap-2">
                <label for="email-address" class="text-sm text-[#8e9fa2] font-medium">Alamat Email (Tidak dapat diubah)</label>
                <input type="email" id="email-address" disabled class="bg-white/2 border border-white/5 rounded-xl py-3.5 px-4 text-white/50 font-inherit text-sm cursor-not-allowed" />
              </div>
            </div>

            <div class="flex flex-col gap-2">
              <label for="new-password" class="text-sm text-[#8e9fa2] font-medium">Kata Sandi Baru (Kosongkan jika tidak ingin mengubah)</label>
              <input type="password" id="new-password" placeholder="Minimal 8 karakter jika ingin diubah" class="bg-white/2 border border-white/5 rounded-xl py-3.5 px-4 text-white font-inherit text-sm transition-all focus:outline-none focus:border-accent/40" />
            </div>
          </div>

          <div id="settings-status-msg" class="hidden text-sm rounded-xl py-3 px-4"></div>

          <div class="flex justify-end gap-4 mt-2">
            <button type="button" id="cancel-btn" class="bg-none border border-white/6 text-[#8e9fa2] py-3.5 px-7 rounded-xl font-semibold text-sm cursor-pointer transition-all duration-200 hover:border-white/15 hover:text-white">Batal</button>
            <button type="submit" id="save-btn" class="bg-accent text-[#080c0d] border-none rounded-xl py-3.5 px-7 font-semibold text-sm cursor-pointer transition-all duration-200 hover:bg-accent-hover hover:-translate-y-0.5">Simpan Perubahan</button>
          </div>
        </form>
      </main>
    </div>
  </div>
</Sidebar>

<script>
  import { isLoggedIn, getToken, updateLocalUser } from '../utils/auth.js';
  import { apiGetProfile, apiUpdateProfile } from '../utils/api.js';

  document.addEventListener('astro:page-load', async () => {
    // 1. Cek login
    if (!isLoggedIn()) {
      window.location.href = '/auth';
      return;
    }

    const token = getToken();
    const profileForm = document.getElementById('profile-form');
    const nameInput = document.getElementById('display-name');
    const emailInput = document.getElementById('email-address');
    const passwordInput = document.getElementById('new-password');
    const fileInput = document.getElementById('profile-photo-input');
    const changePhotoBtn = document.getElementById('change-photo-btn');
    const removePhotoBtn = document.getElementById('remove-photo-btn');
    const photoContainer = document.getElementById('profile-photo-container');
    const statusMsg = document.getElementById('settings-status-msg');
    const saveBtn = document.getElementById('save-btn');
    const cancelBtn = document.getElementById('cancel-btn');

    let currentPhotoUrl = null;
    let selectedFile = null;

    // Helper: set loading button
    function setBtnLoading(button, isLoading, originalText) {
      if (button) {
        if (isLoading) {
          button.disabled = true;
          button.textContent = 'Memproses...';
          button.classList.add('opacity-60', 'cursor-wait');
        } else {
          button.disabled = false;
          button.textContent = originalText;
          button.classList.remove('opacity-60', 'cursor-wait');
        }
      }
    }

    // Helper: show status message
    function showMsg(message, isSuccess = true) {
      if (statusMsg) {
        statusMsg.textContent = message;
        statusMsg.classList.remove('hidden', 'bg-red-400/8', 'border-red-400/15', 'text-red-400', 'bg-emerald-400/8', 'border-emerald-400/15', 'text-emerald-400');
        statusMsg.classList.add('border');
        
        if (isSuccess) {
          statusMsg.classList.add('bg-emerald-400/8', 'border-emerald-400/15', 'text-emerald-400');
        } else {
          statusMsg.classList.add('bg-red-400/8', 'border-red-400/15', 'text-red-400');
        }
      }
    }

    // Render photo container
    function renderPhoto(url) {
      if (photoContainer) {
        if (url) {
          photoContainer.innerHTML = `<img src="${url}" alt="Photo" class="w-full h-full object-cover" />`;
        } else {
          photoContainer.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>`;
        }
      }
    }

    // 2. Load data profil dari backend
    try {
      if (window.__settingDataCache) {
        const user = window.__settingDataCache;
        if (nameInput) nameInput.value = user.name || '';
        if (emailInput) emailInput.value = user.email || '';
        
        currentPhotoUrl = user.photo;
        renderPhoto(currentPhotoUrl);
      } else {
        const response = await apiGetProfile(token);
        if (response.ok && response.data.success) {
          const user = response.data.data;
          window.__settingDataCache = user;
          
          if (nameInput) nameInput.value = user.name || '';
          if (emailInput) emailInput.value = user.email || '';
          
          currentPhotoUrl = user.photo;
          renderPhoto(currentPhotoUrl);
        } else {
          showMsg(response.data.message || 'Gagal memuat profil', false);
        }
      }
    } catch (err) {
      showMsg('Gagal terhubung ke server untuk memuat profil.', false);
    }

    // 3. Trigger input file klik
    changePhotoBtn?.addEventListener('click', () => {
      fileInput?.click();
    });

    // 4. Handle seleksi file gambar baru
    fileInput?.addEventListener('change', (e) => {
      const file = e.target.files?.[0];
      if (file) {
        selectedFile = file;
        const reader = new FileReader();
        reader.onload = (event) => {
          renderPhoto(event.target?.result);
        };
        reader.readAsDataURL(file);
      }
    });

    // 5. Handle hapus foto (set default/kosong)
    removePhotoBtn?.addEventListener('click', () => {
      selectedFile = null;
      if (fileInput) fileInput.value = '';
      currentPhotoUrl = null;
      renderPhoto(null);
    });

    // 6. Handle tombol batal
    cancelBtn?.addEventListener('click', () => {
      window.location.href = '/';
    });

    // 7. Simpan perubahan profil
    profileForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const newName = nameInput.value.trim();
      const newPassword = passwordInput.value;

      if (!newName) {
        showMsg('Nama tampilan tidak boleh kosong.', false);
        return;
      }

      if (newPassword && newPassword.length < 8) {
        showMsg('Kata sandi baru minimal harus 8 karakter.', false);
        return;
      }

      setBtnLoading(saveBtn, true, 'Simpan Perubahan');
      
      const formData = new FormData();
      formData.append('name', newName);
      
      if (newPassword) {
        formData.append('password', newPassword);
      }

      if (selectedFile) {
        formData.append('photo', selectedFile);
      } else if (currentPhotoUrl === null) {
        formData.append('remove_photo', 'true');
      }

      try {
        const response = await apiUpdateProfile(formData, token);
        if (response.ok && response.data.success) {
          showMsg(response.data.message || 'Profil berhasil diperbarui!');
          const updatedUser = response.data.data;
          window.__settingDataCache = updatedUser;
          
          // Dapatkan path relatif / filename dari URL absolut yang dikembalikan Laravel
          let storagePath = null;
          if (updatedUser.photo) {
            const urlParts = updatedUser.photo.split('/storage/');
            if (urlParts.length > 1) storagePath = urlParts[1];
          }

          // Sinkronisasi data local user di localStorage
          updateLocalUser({
            username: updatedUser.name,
            photo: storagePath
          });

          // Render ulang foto di halaman settings
          currentPhotoUrl = updatedUser.photo;
          renderPhoto(currentPhotoUrl);
          
          // Clear input password
          if (passwordInput) passwordInput.value = '';
          selectedFile = null;
          if (fileInput) fileInput.value = '';

          // Update foto & nama di Sidebar seketika jika ada di halaman
          const sidebarUsername = document.getElementById('sidebar-username');
          const sidebarPhotoContainer = document.getElementById('sidebar-user-photo-container');
          
          if (sidebarUsername) sidebarUsername.textContent = updatedUser.name;
          if (sidebarPhotoContainer) {
            if (updatedUser.photo) {
              sidebarPhotoContainer.innerHTML = `<img src="${updatedUser.photo}" alt="Photo" class="w-full h-full object-cover" />`;
            } else {
              sidebarPhotoContainer.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent/60"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`;
            }
          }

        } else {
          // Ambil error validasi dari Laravel jika ada
          const errors = response.data.errors;
          let errMsg = response.data.message || 'Gagal menyimpan perubahan';
          if (errors) {
            const firstKey = Object.keys(errors)[0];
            if (firstKey && errors[firstKey].length > 0) {
              errMsg = errors[firstKey][0];
            }
          }
          showMsg(errMsg, false);
        }
      } catch (err) {
        showMsg('Terjadi kesalahan koneksi saat mengirim data.', false);
      } finally {
        setBtnLoading(saveBtn, false, 'Simpan Perubahan');
      }
    });
  });
</script>
