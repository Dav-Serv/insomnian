---
import Sidebar from '../layouts/Sidebar.astro';

// Settings Page
---

<Sidebar title="Tidur Nyenyak - Settings" activeTab="setting">
  <div class="max-w-[1100px] mx-auto">
    <header class="mb-10">
      <h1 class="text-3xl font-bold m-0 mb-2 text-white">Pengaturan (Settings)</h1>
      <p class="text-base text-muted m-0">Atur profil, preferensi aplikasi, dan pengingat jadwal tidur Anda.</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-[280px_1fr] gap-8 items-start">
      <!-- Left: Settings Navigation/Subtabs -->
      <aside class="bg-[#0d1618] border border-white/2 rounded-3xl p-4 flex flex-col gap-1.5">
        <button class="flex items-center gap-3 py-3.5 px-4 bg-accent/8 border-none text-accent text-sm font-medium rounded-xl cursor-pointer text-left transition-all duration-200">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          Profil Akun
        </button>
        <button class="flex items-center gap-3 py-3.5 px-4 bg-none border-none text-[#8e9fa2] text-sm font-medium rounded-xl cursor-pointer text-left transition-all duration-200 hover:bg-white/2 hover:text-white">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Jadwal & Pengingat
        </button>
        <button class="flex items-center gap-3 py-3.5 px-4 bg-none border-none text-[#8e9fa2] text-sm font-medium rounded-xl cursor-pointer text-left transition-all duration-200 hover:bg-white/2 hover:text-white">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
          Preferensi Audio
        </button>
        <button class="flex items-center gap-3 py-3.5 px-4 bg-none border-none text-[#8e9fa2] text-sm font-medium rounded-xl cursor-pointer text-left transition-all duration-200 hover:bg-white/2 hover:text-white">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
          Sistem & Privasi
        </button>
      </aside>

      <!-- Right: Settings Form -->
      <main class="flex flex-col gap-6">
        <div class="bg-[#0d1618] border border-white/2 rounded-3xl p-8">
          <h2 class="text-xl font-semibold m-0 mb-6 text-white">Informasi Profil</h2>
          <form class="flex flex-col gap-5">
            <div class="flex items-center gap-6 mb-2">
              <div class="w-20 h-20 rounded-full bg-[#121e20] border-2 border-accent/25 flex items-center justify-center text-accent">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                  <circle cx="12" cy="7" r="4" />
                </svg>
              </div>
              <div class="flex gap-3">
                <button type="button" class="bg-accent/8 border border-accent/20 text-accent py-2.5 px-4.5 rounded-lg text-sm font-semibold cursor-pointer transition-all duration-200 hover:bg-accent/15">Ubah Foto</button>
                <button type="button" class="bg-none border border-white/6 text-[#8e9fa2] py-2.5 px-4.5 rounded-lg text-sm font-medium cursor-pointer transition-all duration-200 hover:border-red-500/30 hover:text-red-400">Hapus</button>
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div class="flex flex-col gap-2">
                <label for="display-name" class="text-sm text-[#8e9fa2] font-medium">Nama Tampilan</label>
                <input type="text" id="display-name" value="Samael" class="bg-white/2 border border-white/5 rounded-xl py-3.5 px-4 text-white font-inherit text-sm transition-all focus:outline-none focus:border-accent/40" />
              </div>
              
              <div class="flex flex-col gap-2">
                <label for="email-address" class="text-sm text-[#8e9fa2] font-medium">Alamat Email</label>
                <input type="email" id="email-address" value="samael@gmail.com" class="bg-white/2 border border-white/5 rounded-xl py-3.5 px-4 text-white font-inherit text-sm transition-all focus:outline-none focus:border-accent/40" />
              </div>
            </div>

            <div class="flex flex-col gap-2">
              <label for="bio" class="text-sm text-[#8e9fa2] font-medium">Bio Singkat</label>
              <textarea id="bio" rows="3" placeholder="Tulis sesuatu tentang pola tidur Anda..." class="bg-white/2 border border-white/5 rounded-xl py-3.5 px-4 text-white font-inherit text-sm transition-all focus:outline-none focus:border-accent/40 resize-none">Pencari tidur nyenyak yang suka mendengarkan suara hujan.</textarea>
            </div>
          </form>
        </div>

        <div class="bg-[#0d1618] border border-white/2 rounded-3xl p-8">
          <h2 class="text-xl font-semibold m-0 mb-6 text-white">Pengaturan Notifikasi Pengingat</h2>
          <div class="flex flex-col gap-5">
            <div class="flex justify-between items-center pb-5 border-b border-white/3 last:border-none last:pb-0">
              <div class="setting-text">
                <h3 class="text-base font-semibold m-0 mb-1 text-white">Pengingat Tidur Malam</h3>
                <p class="text-[13px] text-[#8e9fa2] m-0">Kirim pemberitahuan 30 menit sebelum jam tidur Anda.</p>
              </div>
              <div class="relative w-12 h-6 shrink-0">
                <input type="checkbox" id="reminder-sleep" checked class="sr-only peer" />
                <label for="reminder-sleep" class="absolute cursor-pointer top-0 left-0 right-0 bottom-0 bg-[#1a2729] border border-white/5 rounded-full transition-all duration-350 peer-checked:bg-accent/15 peer-checked:border-accent/30 after:content-[''] after:absolute after:h-[18px] after:w-[18px] after:left-[3px] after:bottom-[2px] after:bg-[#8e9fa2] after:transition-all after:duration-300 after:rounded-full peer-checked:after:translate-x-6 peer-checked:after:bg-accent"></label>
              </div>
            </div>

            <div class="flex justify-between items-center pb-5 border-b border-white/3 last:border-none last:pb-0">
              <div class="setting-text">
                <h3 class="text-base font-semibold m-0 mb-1 text-white">Pengingat Jurnal Pagi</h3>
                <p class="text-[13px] text-[#8e9fa2] m-0">Ingatkan untuk mengisi diary tidur 15 menit setelah bangun.</p>
              </div>
              <div class="relative w-12 h-6 shrink-0">
                <input type="checkbox" id="reminder-diary" checked class="sr-only peer" />
                <label for="reminder-diary" class="absolute cursor-pointer top-0 left-0 right-0 bottom-0 bg-[#1a2729] border border-white/5 rounded-full transition-all duration-350 peer-checked:bg-accent/15 peer-checked:border-accent/30 after:content-[''] after:absolute after:h-[18px] after:w-[18px] after:left-[3px] after:bottom-[2px] after:bg-[#8e9fa2] after:transition-all after:duration-300 after:rounded-full peer-checked:after:translate-x-6 peer-checked:after:bg-accent"></label>
              </div>
            </div>
          </div>
        </div>

        <div class="flex justify-end gap-4 mt-2">
          <button type="button" class="bg-none border border-white/6 text-[#8e9fa2] py-3.5 px-7 rounded-xl font-semibold text-sm cursor-pointer transition-all duration-200 hover:border-white/15 hover:text-white">Batal</button>
          <button type="submit" class="bg-accent text-[#080c0d] border-none rounded-xl py-3.5 px-7 font-semibold text-sm cursor-pointer transition-all duration-200 hover:bg-accent-hover hover:-translate-y-0.5">Simpan Perubahan</button>
        </div>
      </main>
    </div>
  </div>
</Sidebar>
