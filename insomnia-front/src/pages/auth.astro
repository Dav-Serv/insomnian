---
import Sidebar from '../layouts/Sidebar.astro';

// Auth Page — Register / Login
---

<Sidebar title="Tidur Nyenyak - Masuk">
  <div class="w-full flex items-center justify-center min-h-[70vh]">
    <div class="w-full max-w-[440px]">

      <!-- Header -->
      <div class="text-center mb-8" id="auth-header">
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-accent/8 border border-accent/15 mb-5">
          <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="currentColor" class="text-accent">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
          </svg>
        </div>
        <h1 class="text-[26px] font-bold text-white m-0 mb-2" id="auth-title">Buat Akun Baru</h1>
        <p class="text-sm text-muted m-0" id="auth-subtitle">Mulai perjalanan tidur nyenyak Anda bersama kami.</p>
      </div>

      <!-- Auth Card -->
      <div class="bg-[#0d1618] border border-white/5 rounded-3xl p-8">
        
        <!-- Register Form -->
        <form id="register-form" class="flex flex-col gap-5">
          <div class="flex flex-col gap-2">
            <label for="reg-username" class="text-sm text-muted font-medium">Nama Pengguna</label>
            <div class="relative">
              <div class="absolute left-4 top-1/2 -translate-y-1/2 text-muted pointer-events-none">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              </div>
              <input type="text" id="reg-username" placeholder="Masukkan nama pengguna" required
                class="w-full bg-white/2 border border-white/5 rounded-xl py-3.5 pl-11 pr-4 text-white font-inherit text-sm transition-all duration-200 focus:outline-none focus:border-accent/40 focus:bg-white/3 placeholder:text-white/20 box-border" />
            </div>
          </div>

          <div class="flex flex-col gap-2">
            <label for="reg-email" class="text-sm text-muted font-medium">Alamat Email</label>
            <div class="relative">
              <div class="absolute left-4 top-1/2 -translate-y-1/2 text-muted pointer-events-none">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
              <input type="email" id="reg-email" placeholder="nama@email.com" required
                class="w-full bg-white/2 border border-white/5 rounded-xl py-3.5 pl-11 pr-4 text-white font-inherit text-sm transition-all duration-200 focus:outline-none focus:border-accent/40 focus:bg-white/3 placeholder:text-white/20 box-border" />
            </div>
          </div>

          <div class="flex flex-col gap-2">
            <label for="reg-password" class="text-sm text-muted font-medium">Kata Sandi</label>
            <div class="relative">
              <div class="absolute left-4 top-1/2 -translate-y-1/2 text-muted pointer-events-none">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              </div>
              <input type="password" id="reg-password" placeholder="Minimal 6 karakter" required minlength="6"
                class="w-full bg-white/2 border border-white/5 rounded-xl py-3.5 pl-11 pr-4 text-white font-inherit text-sm transition-all duration-200 focus:outline-none focus:border-accent/40 focus:bg-white/3 placeholder:text-white/20 box-border" />
              <button type="button" id="reg-toggle-pw" class="absolute right-4 top-1/2 -translate-y-1/2 text-muted hover:text-white bg-transparent border-none cursor-pointer p-0 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
              </button>
            </div>
          </div>

          <div class="flex flex-col gap-2">
            <label for="reg-photo" class="text-sm text-muted font-medium">Foto Profil (Opsional)</label>
            <input type="file" id="reg-photo" accept="image/*"
              class="w-full bg-white/2 border border-white/5 rounded-xl py-3 px-4 text-white font-inherit text-sm transition-all duration-200 focus:outline-none focus:border-accent/40 file:mr-4 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-accent/10 file:text-accent hover:file:bg-accent/20 cursor-pointer" />
          </div>

          <!-- Error message -->
          <div id="reg-error" class="hidden text-red-400 text-sm bg-red-400/8 border border-red-400/15 rounded-xl py-3 px-4"></div>

          <button type="submit" id="reg-submit"
            class="w-full bg-accent text-[#080c0d] border-none rounded-xl py-3.5 px-7 font-semibold text-sm cursor-pointer transition-all duration-200 hover:bg-accent-hover hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(78,208,200,0.25)] mt-1">
            Buat Akun
          </button>
        </form>

        <!-- Login Form (hidden by default) -->
        <form id="login-form" class="hidden flex flex-col gap-5">
          <div class="flex flex-col gap-2">
            <label for="login-email" class="text-sm text-muted font-medium">Alamat Email</label>
            <div class="relative">
              <div class="absolute left-4 top-1/2 -translate-y-1/2 text-muted pointer-events-none">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
              <input type="email" id="login-email" placeholder="nama@email.com" required
                class="w-full bg-white/2 border border-white/5 rounded-xl py-3.5 pl-11 pr-4 text-white font-inherit text-sm transition-all duration-200 focus:outline-none focus:border-accent/40 focus:bg-white/3 placeholder:text-white/20 box-border" />
            </div>
          </div>

          <div class="flex flex-col gap-2">
            <div class="flex justify-between items-center">
              <label for="login-password" class="text-sm text-muted font-medium">Kata Sandi</label>
              <a href="#" class="text-xs text-accent no-underline hover:opacity-80 transition-opacity">Lupa kata sandi?</a>
            </div>
            <div class="relative">
              <div class="absolute left-4 top-1/2 -translate-y-1/2 text-muted pointer-events-none">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              </div>
              <input type="password" id="login-password" placeholder="Masukkan kata sandi" required
                class="w-full bg-white/2 border border-white/5 rounded-xl py-3.5 pl-11 pr-4 text-white font-inherit text-sm transition-all duration-200 focus:outline-none focus:border-accent/40 focus:bg-white/3 placeholder:text-white/20 box-border" />
              <button type="button" id="login-toggle-pw" class="absolute right-4 top-1/2 -translate-y-1/2 text-muted hover:text-white bg-transparent border-none cursor-pointer p-0 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
              </button>
            </div>
          </div>

          <!-- Error message -->
          <div id="login-error" class="hidden text-red-400 text-sm bg-red-400/8 border border-red-400/15 rounded-xl py-3 px-4"></div>

          <button type="submit" id="login-submit"
            class="w-full bg-accent text-[#080c0d] border-none rounded-xl py-3.5 px-7 font-semibold text-sm cursor-pointer transition-all duration-200 hover:bg-accent-hover hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(78,208,200,0.25)] mt-1">
            Masuk
          </button>
        </form>

        <!-- Divider -->
        <div class="flex items-center gap-4 my-6">
          <div class="flex-1 h-px bg-white/5"></div>
          <span class="text-xs text-muted">atau</span>
          <div class="flex-1 h-px bg-white/5"></div>
        </div>

        <!-- Toggle Link -->
        <p class="text-center text-sm text-muted m-0">
          <span id="toggle-text-label">Sudah punya akun?</span>
          <button type="button" id="toggle-auth-mode"
            class="text-accent font-semibold bg-transparent border-none cursor-pointer p-0 hover:opacity-80 transition-opacity text-sm ml-1">
            Masuk
          </button>
        </p>
      </div>

    </div>
  </div>
</Sidebar>

<script>
  import { register, login } from '../utils/auth.js';

  document.addEventListener('DOMContentLoaded', () => {
    const registerForm = document.getElementById('register-form');
    const loginForm = document.getElementById('login-form');
    const toggleBtn = document.getElementById('toggle-auth-mode');
    const toggleLabel = document.getElementById('toggle-text-label');
    const authTitle = document.getElementById('auth-title');
    const authSubtitle = document.getElementById('auth-subtitle');

    let isRegisterMode = true;

    // Toggle between register and login
    toggleBtn.addEventListener('click', () => {
      isRegisterMode = !isRegisterMode;

      if (isRegisterMode) {
        registerForm.classList.remove('hidden');
        loginForm.classList.add('hidden');
        authTitle.textContent = 'Buat Akun Baru';
        authSubtitle.textContent = 'Mulai perjalanan tidur nyenyak Anda bersama kami.';
        toggleLabel.textContent = 'Sudah punya akun?';
        toggleBtn.textContent = 'Masuk';
      } else {
        registerForm.classList.add('hidden');
        loginForm.classList.remove('hidden');
        authTitle.textContent = 'Selamat Datang Kembali';
        authSubtitle.textContent = 'Masuk untuk melanjutkan perjalanan tidur nyenyak Anda.';
        toggleLabel.textContent = 'Belum punya akun?';
        toggleBtn.textContent = 'Daftar';
      }
    });

    // Toggle password visibility — Register
    const regTogglePw = document.getElementById('reg-toggle-pw');
    const regPassword = document.getElementById('reg-password');
    regTogglePw?.addEventListener('click', () => {
      const isPassword = regPassword.type === 'password';
      regPassword.type = isPassword ? 'text' : 'password';
      regTogglePw.querySelector('svg').innerHTML = isPassword
        ? '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>'
        : '<path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/>';
    });

    // Toggle password visibility — Login
    const loginTogglePw = document.getElementById('login-toggle-pw');
    const loginPassword = document.getElementById('login-password');
    loginTogglePw?.addEventListener('click', () => {
      const isPassword = loginPassword.type === 'password';
      loginPassword.type = isPassword ? 'text' : 'password';
      loginTogglePw.querySelector('svg').innerHTML = isPassword
        ? '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>'
        : '<path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/>';
    });

    // Helper: set loading state pada tombol
    function setLoading(button, isLoading, originalText) {
      if (button) {
        if (isLoading) {
          button.disabled = true;
          button.textContent = 'Memproses...';
          button.classList.add('opacity-60', 'cursor-wait');
        } else {
          button.disabled = false;
          button.textContent = originalText;
          button.classList.remove('opacity-60', 'cursor-wait');
        }
      }
    }

    // Register form submit
    registerForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const username = document.getElementById('reg-username').value.trim();
      const email = document.getElementById('reg-email').value.trim();
      const password = document.getElementById('reg-password').value;
      const photoEl = document.getElementById('reg-photo');
      const errorEl = document.getElementById('reg-error');
      const submitBtn = document.getElementById('reg-submit');

      if (username.length < 3) {
        errorEl.textContent = 'Nama pengguna minimal 3 karakter.';
        errorEl.classList.remove('hidden');
        return;
      }

      if (password.length < 8) {
        errorEl.textContent = 'Kata sandi minimal 8 karakter (sesuai standar backend).';
        errorEl.classList.remove('hidden');
        return;
      }

      const photo = photoEl && photoEl.files && photoEl.files[0] ? photoEl.files[0] : null;

      errorEl.classList.add('hidden');
      setLoading(submitBtn, true, 'Buat Akun');
      if (typeof window.showMoonLoader === 'function') {
        window.showMoonLoader('Sedang Mendaftar Akun...');
      }

      const result = await register({ username, email, password, photo });
      if (result.success) {
        window.location.href = '/';
      } else {
        if (typeof window.hideMoonLoader === 'function') {
          window.hideMoonLoader();
        }
        errorEl.textContent = result.message || 'Registrasi gagal. Silakan coba lagi.';
        errorEl.classList.remove('hidden');
        setLoading(submitBtn, false, 'Buat Akun');
      }
    });

    // Login form submit
    loginForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = document.getElementById('login-email').value.trim();
      const password = document.getElementById('login-password').value;
      const errorEl = document.getElementById('login-error');
      const submitBtn = document.getElementById('login-submit');

      if (!email || !password) {
        errorEl.textContent = 'Semua kolom harus diisi.';
        errorEl.classList.remove('hidden');
        return;
      }

      errorEl.classList.add('hidden');
      setLoading(submitBtn, true, 'Masuk');
      if (typeof window.showMoonLoader === 'function') {
        window.showMoonLoader('Sedang Masuk ke Akun...');
      }

      const result = await login({ email, password });
      if (result.success) {
        window.location.href = '/';
      } else {
        if (typeof window.hideMoonLoader === 'function') {
          window.hideMoonLoader();
        }
        errorEl.textContent = result.message || 'Email atau kata sandi salah.';
        errorEl.classList.remove('hidden');
        setLoading(submitBtn, false, 'Masuk');
      }
    });
  });
</script>

