---
import Sidebar from '../layouts/Sidebar.astro';

// Soundscape Catalog Page - Nusantara Soundscape
---

<Sidebar title="Tidur Nyenyak - Soundscape" activeTab="soundscape">
  <div class="w-full">
    <!-- Header -->
    <header class="mb-8">
      <h1 class="text-[32px] font-bold m-0 mb-3 text-white leading-tight">Nusantara Soundscape</h1>
      <p class="text-[15px] text-muted m-0 leading-relaxed max-w-2xl">
        Immerse yourself in the restorative sounds of the archipelago. Curated acoustic environments designed to lower heart rate and prepare the mind for deep sleep.
      </p>
    </header>

    <!-- Category Filters -->
    <div id="category-filters-container" class="flex gap-2.5 mb-8 overflow-x-auto pb-2 flex-wrap">
      <!-- Buttons will be rendered dynamically by JavaScript -->
    </div>

    <!-- Soundscape Cards Grid -->
    <div id="tracks-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="col-span-full py-20 text-center text-muted">
        Memuat daftar lagu...
      </div>
    </div>
  </div>
</Sidebar>

<script>
  import { isLoggedIn, getToken } from '../utils/auth.js';
  import { apiGetSoundscapes, apiToggleFavorite, apiGetFavorites } from '../utils/api.js';

  document.addEventListener('astro:page-load', () => {
    // Hanya jalankan logika ini jika kita berada di halaman soundscape
    const filtersContainer = document.getElementById('category-filters-container');
    const tracksGrid = document.getElementById('tracks-grid');
    if (!filtersContainer || !tracksGrid) return;

    const isUserLoggedIn = isLoggedIn();
    const token = getToken();

    // State Variables
    let categories = ['All Sounds', 'Nature', 'Rain', 'Traditional', 'Binaural'];
    if (isUserLoggedIn) {
      categories.push('Favorit');
    }
    let currentCategory = 'all';
    let tracks = [];

    // Initialize category filters
    function initFilters() {
      if (!filtersContainer) return;
      filtersContainer.innerHTML = '';

      categories.forEach((cat) => {
        const catKey = cat === 'All Sounds' ? 'all' : cat.toLowerCase();
        const isActive = currentCategory === catKey;

        const button = document.createElement('button');
        button.textContent = cat;
        button.className = `py-2 px-5 rounded-full text-[13px] font-medium cursor-pointer whitespace-nowrap transition-all duration-200 border ${
          isActive
            ? 'bg-accent text-[#080c0d] border-accent shadow-[0_0_12px_rgba(78,208,200,0.2)]'
            : 'bg-white/4 border-white/8 text-muted hover:text-white hover:bg-white/8 hover:border-white/15'
        }`;

        button.addEventListener('click', () => {
          currentCategory = catKey;
          initFilters();
          loadTracks();
        });

        filtersContainer.appendChild(button);
      });
    }

    // Fetch tracks from API based on category filter
    async function loadTracks() {
      if (!tracksGrid) return;
      tracksGrid.innerHTML = `
        <div class="col-span-full py-20 flex flex-col items-center justify-center gap-4 text-muted">
          <div class="moon-spinner"></div>
          <span class="text-sm">Memuat daftar lagu...</span>
        </div>
      `;

      try {
        let res;
        if (currentCategory === 'favorit') {
          res = await apiGetFavorites(token);
        } else {
          res = await apiGetSoundscapes(currentCategory, token);
        }

        if (res.ok && res.data.success) {
          tracks = res.data.data;
          renderTracks();
        } else {
          tracksGrid.innerHTML = `
            <div class="col-span-full py-12 text-center text-red-400">
              Gagal memuat lagu. ${res.data.message || ''}
            </div>
          `;
        }
      } catch (err) {
        tracksGrid.innerHTML = `
          <div class="col-span-full py-12 text-center text-red-400">
            Terjadi kesalahan koneksi server.
          </div>
        `;
      }
    }

    // Render tracks into grid cards
    function renderTracks() {
      if (!tracksGrid) return;
      if (tracks.length === 0) {
        tracksGrid.innerHTML = `
          <div class="col-span-full py-20 text-center text-muted">
            Tidak ada lagu di kategori ini.
          </div>
        `;
        return;
      }

      // Dapatkan ID lagu yang sedang diputar untuk highlight visual
      const currentPlayingId = window.audioPlayer?.getCurrentTrackId?.();

      tracksGrid.innerHTML = '';
      tracks.forEach((track, index) => {
        const isFavorited = track.is_favorited;
        const isCurrentlyPlaying = track.id === currentPlayingId;

        const card = document.createElement('div');
        card.className = `group cursor-pointer transition-all duration-300 hover:-translate-y-1 ${isCurrentlyPlaying ? 'ring-2 ring-accent/40 rounded-2xl' : ''}`;

        card.innerHTML = `
          <!-- Image Container -->
          <div class="relative rounded-2xl overflow-hidden mb-4 aspect-[16/11] bg-[#121e20] border border-white/5 flex items-center justify-center">
            <img
              src="${track.thumbnail_url || 'data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22100%22 height=%22100%22><rect width=%22100%22 height=%22100%22 fill=%22%231a2729%22/></svg>'}"
              alt="${track.title}"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
            <div class="absolute top-3 left-3 bg-black/50 backdrop-blur-sm border border-white/10 rounded-md py-1 px-2.5">
              <span class="text-[11px] font-semibold text-white capitalize">${track.category}</span>
            </div>
            ${isCurrentlyPlaying ? `
              <div class="absolute bottom-3 right-3 bg-accent/90 text-[#080c0d] rounded-full p-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
              </div>
            ` : ''}
          </div>

          <!-- Card Info -->
          <div class="px-0.5">
            <h3 class="text-[16px] font-semibold ${isCurrentlyPlaying ? 'text-accent' : 'text-white'} m-0 mb-1.5 group-hover:text-accent transition-colors truncate">${track.title}</h3>
            <p class="text-[13px] text-muted m-0 mb-3 leading-relaxed line-clamp-2">${track.description || 'Tidak ada deskripsi.'}</p>

            <!-- Footer -->
            <div class="flex justify-between items-center">
              <div class="flex items-center gap-1.5 text-muted">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/>
                  <polyline points="12 6 12 12 16 14"/>
                </svg>
                <span class="text-[12px]">${track.duration_minutes} min</span>
              </div>
              <button class="favorite-toggle-btn bg-transparent border-none cursor-pointer p-1 transition-transform active:scale-95 ${
                isFavorited ? 'text-accent' : 'text-muted hover:text-accent'
              }" data-id="${track.id}" title="${isFavorited ? 'Hapus dari Favorit' : 'Tambah ke Favorit'}">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="${
                  isFavorited ? 'currentColor' : 'none'
                }" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                </svg>
              </button>
            </div>
          </div>
        `;

        // Klik pada gambar/judul memutar lagu melalui API global audioPlayer
        card.querySelector('.aspect-\\[16\\/11\\]')?.addEventListener('click', () => {
          window.audioPlayer?.playTrack(track, tracks, index);
        });
        card.querySelector('h3')?.addEventListener('click', () => {
          window.audioPlayer?.playTrack(track, tracks, index);
        });

        // Handle Favorite Button Click
        const favBtn = card.querySelector('.favorite-toggle-btn');
        favBtn?.addEventListener('click', async (e) => {
          e.stopPropagation(); // prevent playing when clicking fav
          if (!isUserLoggedIn) {
            alert('Silakan login terlebih dahulu untuk menyukai lagu.');
            window.location.href = '/auth';
            return;
          }

          try {
            const trackId = favBtn.getAttribute('data-id');
            const res = await apiToggleFavorite(trackId, token);
            if (res.ok && res.data.success) {
              // Update state locally
              track.is_favorited = res.data.is_favorited;
              
              const svg = favBtn.querySelector('svg');
              if (track.is_favorited) {
                favBtn.className = 'favorite-toggle-btn bg-transparent border-none cursor-pointer p-1 text-accent';
                svg.setAttribute('fill', 'currentColor');
              } else {
                favBtn.className = 'favorite-toggle-btn bg-transparent border-none cursor-pointer p-1 text-muted hover:text-accent';
                svg.setAttribute('fill', 'none');
                
                // If on favorit tab, remove from grid instantly
                if (currentCategory === 'favorit') {
                  loadTracks();
                }
              }
            }
          } catch (err) {
            console.error('Error toggling favorite:', err);
          }
        });

        tracksGrid.appendChild(card);
      });
    }

    // Execute setup
    initFilters();
    loadTracks();
  });
</script>
