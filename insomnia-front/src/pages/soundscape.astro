---
import Sidebar from '../layouts/Sidebar.astro';

// Soundscape Catalog Page - Nusantara Soundscape
const soundscapes = [
  {
    id: 'ubud-forest',
    name: 'Ubud Forest Canopy',
    category: 'Nature',
    description: 'Gentle rustling leaves and distant nocturnal wildlife...',
    duration: '45 min',
    image: '/ubud-forest.png',
  },
  {
    id: 'monsoon-downpour',
    name: 'Monsoon Downpour',
    category: 'Rain',
    description: 'Steady, heavy rainfall typical of the tropical wet season,...',
    duration: '∞ Continuous',
    image: '/monsoon-downpour.png',
  },
  {
    id: 'midnight-gamelan',
    name: 'Midnight Gamelan',
    category: 'Traditional',
    description: 'Slow, resonant tones of traditional bronze percussion...',
    duration: '60 min',
    image: '/midnight-gamelan.png',
  },
];

const categories = ['All Sounds', 'Nature', 'Rain', 'Traditional', 'Binaural'];
---

<Sidebar title="Tidur Nyenyak - Soundscape" activeTab="soundscape">
  <div class="w-full">
    <!-- Header -->
    <header class="mb-8">
      <h1 class="text-[32px] font-bold m-0 mb-3 text-white leading-tight">Nusantara Soundscape</h1>
      <p class="text-[15px] text-muted m-0 leading-relaxed max-w-2xl">
        Immerse yourself in the restorative sounds of the archipelago. Curated acoustic environments designed to lower heart rate and prepare the mind for deep sleep.
      </p>
    </header>

    <!-- Category Filters -->
    <div class="flex gap-2.5 mb-8 overflow-x-auto pb-2 flex-wrap">
      {categories.map((cat, i) => (
        <button
          class:list={[
            'py-2 px-5 rounded-full text-[13px] font-medium cursor-pointer whitespace-nowrap transition-all duration-200 border',
            i === 0
              ? 'bg-accent text-[#080c0d] border-accent shadow-[0_0_12px_rgba(78,208,200,0.2)]'
              : 'bg-white/4 border-white/8 text-muted hover:text-white hover:bg-white/8 hover:border-white/15'
          ]}
        >
          {cat}
        </button>
      ))}
    </div>

    <!-- Soundscape Cards Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {soundscapes.map(track => (
        <div class="group cursor-pointer transition-all duration-300 hover:-translate-y-1">
          <!-- Image Container -->
          <div class="relative rounded-2xl overflow-hidden mb-4 aspect-[16/11]">
            <img
              src={track.image}
              alt={track.name}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
            <!-- Category Badge -->
            <div class="absolute top-3 left-3 bg-black/50 backdrop-blur-sm border border-white/10 rounded-md py-1 px-2.5">
              <span class="text-[11px] font-semibold text-white">{track.category}</span>
            </div>
          </div>

          <!-- Card Info -->
          <div class="px-0.5">
            <h3 class="text-[16px] font-semibold text-white m-0 mb-1.5 group-hover:text-accent transition-colors">{track.name}</h3>
            <p class="text-[13px] text-muted m-0 mb-3 leading-relaxed line-clamp-2">{track.description}</p>

            <!-- Footer -->
            <div class="flex justify-between items-center">
              <div class="flex items-center gap-1.5 text-muted">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/>
                  <polyline points="12 6 12 12 16 14"/>
                </svg>
                <span class="text-[12px]">{track.duration}</span>
              </div>
              <button class="bg-transparent border-none cursor-pointer text-muted hover:text-accent transition-colors p-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                </svg>
              </button>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</Sidebar>
